# Copy to .env.local before running the frontend.

# URL of the FastAPI backend
NEXT_PUBLIC_API_URL=http://localhost:8000

# Password for the dashboard login gate
# Leave unset to disable the password requirement (any password accepted)
DASHBOARD_PASSWORD=change-me

# API key sent as Bearer token to the backend (must match backend API_KEY)
NEXT_PUBLIC_API_KEY=change-me
