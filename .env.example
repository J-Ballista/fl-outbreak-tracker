# Copy this file to .env and fill in values before running the backend.

# PostgreSQL connection string (asyncpg driver for FastAPI, psycopg2 for Alembic)
DATABASE_URL=postgresql+asyncpg://postgres:devpassword@localhost:5432/fl_outbreak

# API key for protecting all /api/* routes.
# Leave unset or empty to disable auth (local dev).
# The frontend must send: Authorization: Bearer <value>
API_KEY=change-me
